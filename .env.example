# Required: get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model + safety
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_ITERATIONS=16
AGENT_AUTO_CONFIRM=false

# Storage
REDIS_URL=redis://redis:6379/0
CHROMA_DIR=/app/data/chroma
WORKSPACE_ROOT=/app/data/workspaces

# CORS (comma-separated origins; "*" for any)
CORS_ORIGINS=*

# SMTP — leave blank to dry-run send_email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
